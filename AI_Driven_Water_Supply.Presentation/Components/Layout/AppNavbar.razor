@using AI_Driven_Water_Supply.Application.Interfaces
@rendermode InteractiveServer

@if (IsGuest)
{
    <div class="app-navbar-glass">
        <div class="app-navbar-brand">
            <a href="/" class="app-navbar-brand-link">
                <i class="fa-solid fa-droplet"></i> HydroAI
            </a>
        </div>
        <div class="app-navbar-icons">
            <AuthButton />
        </div>
    </div>
}
else if (IsConsumer)
{
    <div class="app-navbar-glass">
        <div class="app-navbar-brand">
            <a href="/Consumer" class="app-navbar-brand-link">
                <i class="fa-solid fa-droplet"></i> HydroAI
            </a>
        </div>
        <div class="app-navbar-icons">
            <div style="position: relative;">
                <div class="app-navbar-icon-btn @(_showMsgDropdown ? "active" : "")" @onclick="ToggleMsgDropdown">
                    <i class="fa-regular fa-comment-dots"></i>
                    @if (_consumerChatList.Any(c => c.UnreadCount > 0))
                    {
                        <span class="app-navbar-badge-dot"></span>
                    }
                </div>
                <div class="app-navbar-dropdown app-navbar-msg-dropdown @(_showMsgDropdown ? "show" : "")">
                    <div class="d-flex justify-content-between align-items-center px-3 py-2">
                        <h6 class="text-white m-0 small fw-bold" style="color: #888 !important;">CHATS</h6>
                        <small class="text-muted" style="cursor:pointer" @onclick="RefreshConsumerChats"><i class="fa-solid fa-rotate-right"></i></small>
                    </div>
                    <div style="height: 1px; background: rgba(255,255,255,0.1); margin: 5px 0;"></div>
                    <div style="max-height: 350px; overflow-y: auto;">
                        @if (_consumerChatLoading)
                        {
                            <div class="p-4 text-center text-muted small"><div class="spinner-border spinner-border-sm text-info"></div> Loading...</div>
                        }
                        else if (_consumerChatList.Count == 0)
                        {
                            <div class="p-4 text-center text-muted small">No active conversations.</div>
                        }
                        else
                        {
                            @foreach (var chat in _consumerChatList)
                            {
                                <div class="app-navbar-chat-item" @onclick="() => OpenChat(chat.OrderId)">
                                    <div class="app-navbar-supplier-avatar">@(!string.IsNullOrEmpty(chat.SupplierName) ? chat.SupplierName.Substring(0, 1).ToUpper() : "S")</div>
                                    <div class="app-navbar-chat-info" style="flex:1;">
                                        <div class="app-navbar-chat-name">
                                            @chat.SupplierName
                                            <span class="app-navbar-chat-time">@chat.LastMsgTime</span>
                                        </div>
                                        <div class="app-navbar-chat-msg">
                                            @if (chat.IsLastMsgFromMe)
                                            {
                                                <i class="bi bi-check2-all text-info me-1"></i>
                                            }
                                            @chat.LastMessage
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
            <div style="position: relative;">
                <div class="app-navbar-profile-trigger" @onclick="ToggleProfileDropdown">
                    <img src="@_profileImageUrl" alt="Profile">
                </div>
                <div class="app-navbar-profile-menu @(_showProfileDropdown ? "show" : "")">
                    <a href="/profilepro" class="app-navbar-menu-link"><i class="bi bi-person"></i> My Profile</a>
                    <a href="/Cardpage" class="app-navbar-menu-link"><i class="bi bi-box-seam"></i> My Orders</a>
                    <a href="/bills" class="app-navbar-menu-link"><i class="bi bi-receipt"></i> Billing</a>
                    <div class="app-navbar-menu-divider"></div>
                    <a href="#" class="app-navbar-menu-link app-navbar-logout-link" @onclick="HandleLogout"><i class="bi bi-box-arrow-right"></i> Logout</a>
                </div>
            </div>
        </div>
    </div>
}
else if (IsProvider)
{
    <div class="app-navbar-glass">
        <div class="app-navbar-brand">
            <a href="/ProviderDashboard" class="app-navbar-brand-link">
                <i class="fa-solid fa-droplet"></i> HydroAI
            </a>
        </div>
        <div class="app-navbar-icons">
            <div class="app-navbar-icon-btn" @onclick="ToggleProviderSidebar" title="Messages">
                <i class="fa-regular fa-comment-dots"></i>
                @if (_providerChatList.Count > 0)
                {
                    <span class="app-navbar-badge-dot"></span>
                }
            </div>
            <a href="/provider-reviews" class="app-navbar-icon-btn" title="My Reputation"><i class="fa-solid fa-star text-warning"></i></a>
            <a href="/supplier-bills" class="app-navbar-icon-btn" title="Earnings & Bills"><i class="fa-solid fa-file-invoice-dollar"></i></a>
            <a href="/attendance" class="app-navbar-icon-btn" title="Staff Attendance"><i class="fa-solid fa-clipboard-user"></i></a>
            <a href="/profilepro" class="app-navbar-profile-trigger" title="My Profile">
                <img src="@_profileImageUrl" alt="Profile">
            </a>
            <button type="button" class="app-navbar-logout-btn" @onclick="HandleLogout" title="Logout">
                <i class="bi bi-box-arrow-right"></i> Logout
            </button>
        </div>
    </div>

    <div class="app-navbar-sidebar-overlay @(_providerSidebarOpen ? "active" : "")" @onclick="ToggleProviderSidebar"></div>
    <div class="app-navbar-side-panel @(_providerSidebarOpen ? "open" : "")">
        <div class="app-navbar-chat-header mb-3 d-flex justify-content-between align-items-center">
            <div>
                <h4 class="fw-bold m-0 text-white">Inbox</h4>
                <small class="text-muted">You have @_providerChatList.Count active chats</small>
            </div>
            <i class="fa-solid fa-xmark fs-4 text-muted" style="cursor: pointer;" @onclick="ToggleProviderSidebar"></i>
        </div>
        <div class="app-navbar-provider-chat-list">
            @if (_providerChatLoading)
            {
                <div class="text-center text-muted mt-5"><div class="spinner-border spinner-border-sm text-success" role="status"></div></div>
            }
            else if (_providerChatList.Count == 0)
            {
                <div class="text-center text-muted mt-5"><p class="small">No active orders yet.</p></div>
            }
            else
            {
                @foreach (var chat in _providerChatList)
                {
                    <div class="app-navbar-provider-chat-item" @onclick="() => OpenChat(chat.OrderId)">
                        <div class="app-navbar-avatar">
                            @(!string.IsNullOrEmpty(chat.SenderName) ? chat.SenderName.Substring(0, 1).ToUpper() : "U")
                            <div class="app-navbar-online-dot"></div>
                        </div>
                        <div class="app-navbar-msg-content">
                            <h6>@chat.SenderName</h6>
                            <p>@chat.Content</p>
                        </div>
                        <span class="app-navbar-msg-time">@chat.CreatedAt.ToLocalTime().ToString("hh:mm tt")</span>
                    </div>
                }
            }
        </div>
    </div>
}
