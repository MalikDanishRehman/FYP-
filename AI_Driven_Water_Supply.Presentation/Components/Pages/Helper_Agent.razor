@page "/Helper_Agent"
@using System.Text.Json
@using System.Text
@using System.Timers
@rendermode InteractiveServer

<div class="glass-nav">
    <div class="brand-logo"><i class="fa-solid fa-droplet"></i> HydroAI</div>
    <div class="nav-icons">
        <div style="position: relative;">
            <div class="profile-trigger" @onclick="ToggleProfileDropdown">
                <img src="@ProfileImageUrl" alt="Profile">
            </div>
            <div class="custom-dropdown @(showProfileDropdown ? "show" : "")">
                <div class="px-3 py-2 text-center">
                    <span class="text-white fw-bold d-block">@MyName</span>
                    <span class="text-muted small">Consumer</span>
                </div>
                <a href="#" class="chat-item" style="color: #ff4757;" @onclick="HandleLogout">
                    <i class="fa-solid fa-power-off me-2"></i> Logout
                </a>
            </div>
        </div>
    </div>
</div>

<div class="hero-container" @onclick="CloseDropdowns">

    <video id="myVideo" class="@(hasChatStarted ? "video-hidden" : "")" autoplay muted playsinline loop>
        <source src="/video/blob.mp4" type="video/mp4">
    </video>

    <div id="chatContainer" class="chat-scroll-area @(hasChatStarted ? "active" : "")">
        @foreach (var msg in CurrentConversation)
        {
            <div class="msg-bubble @(msg.IsUser ? "msg-user" : "msg-ai")">
                @if (!msg.IsUser)
                {
                    <div style="display:flex; align-items:center; gap:10px; margin-bottom:10px;">
                        <i class="fa-solid fa-robot" style="color:var(--primary-glow);"></i>
                        <strong style="color: var(--secondary-glow)">HydroAI</strong>
                    </div>
                }

                @if (!string.IsNullOrEmpty(msg.ImageUrl))
                {
                    <img src="@msg.ImageUrl" class="chat-image-display" alt="Attached Image" />
                }

                @((MarkupString)msg.Text)
            </div>
        }

        @if (isThinking)
        {
            <div class="msg-bubble msg-ai">
                <div style="display:flex; align-items:center; gap:10px;">
                    <span class="spinner-border spinner-border-sm text-info"></span>
                    <span class="text-muted" style="font-style: italic;">@loadingText</span>
                </div>
            </div>
        }
    </div>

    <div class="chat-input-wrapper">
        @if (!string.IsNullOrEmpty(selectedImagePreview))
        {
            <div class="image-preview-box">
                <img src="@selectedImagePreview" class="preview-thumb" />
                <div style="flex:1; color:#ccc; font-size:0.9rem;">
                    Image Attached
                </div>
                <button type="button" class="remove-img-btn" @onclick="ClearImageAttachment">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
        }

        <div class="chat-input-box">
            <InputFile OnChange="@HandleFileSelection" id="fileInput" style="display:none;" accept="image/*" @key="@inputFileId" />

            <label for="fileInput" class="attach-btn" title="Attach Image">
                <i class="fa-solid fa-paperclip"></i>
            </label>

            <i class="fa-solid fa-sparkles" style="color: var(--primary-glow); margin-left: 10px;"></i>

            <input type="text" @bind="userInput" @bind:event="oninput" @onkeyup="HandleKeyPress"
                   placeholder="Ask 'Show suppliers' or attach image..." disabled="@isThinking" />

            <button class="send-btn" @onclick="SendMessage" disabled="@((string.IsNullOrWhiteSpace(userInput) && string.IsNullOrEmpty(selectedImageBase64)) || isThinking)">
                @if (isThinking)
                {
                    <i class="fa-solid fa-hourglass-half fa-spin"></i>
                }
                else
                {
                    <i class="fa-solid fa-paper-plane"></i>
                }
            </button>
        </div>
    </div>
</div>

<script>
    window.scrollToBottom = (id) => { var el = document.getElementById(id); if (el) el.scrollTop = el.scrollHeight; }
</script>