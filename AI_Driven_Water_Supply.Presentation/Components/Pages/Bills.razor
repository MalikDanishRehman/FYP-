@page "/bills"
@using AI_Driven_Water_Supply.Application.Interfaces

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<div class="container-bills">
    <div class="d-flex align-items-center gap-3 mb-4">
        <button type="button" class="btn btn-outline-light btn-sm" @onclick="GoBack">
            <i class="fa-solid fa-arrow-left me-1"></i> Back to dashboard
        </button>
        <h5 class="mb-0 text-white">My Bills</h5>
    </div>

    <div class="summary-grid">
        <div class="summary-card">
            <div class="summary-label">Total Unpaid</div>
            <div class="summary-val text-danger-neon">Rs @TotalUnpaid</div>
        </div>
        <div class="summary-card">
            <div class="summary-label">Last Paid</div>
            <div class="summary-val text-neon">Rs @LastPaidAmount</div>
        </div>
    </div>

    <div class="section-title">Pending Bills</div>
    <small class="text-muted d-block mb-3">Each bill is tied to the order below. Pay only when you intend to complete the bill.</small>
    @if (pendingBills.Count == 0)
    {
        <p class="text-center text-muted py-3">No pending bills.</p>
    }
    else
    {
        @foreach (var bill in pendingBills)
        {
            <div class="bill-card">
                <div class="bill-info">
                    <div class="bill-icon"><i class="fa-solid fa-bottle-water"></i></div>
                    <div class="bill-details">
                        <h6>Supplier: @bill.SupplierName</h6>
                        <p class="bill-meta">Order #@bill.OrderId • Bill @bill.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</p>
                        @if (OrderFor(bill.OrderId) is { } ord)
                        {
                            <p class="bill-order-line"><i class="fa-solid fa-droplet me-1"></i>@ord.ItemName × @ord.Quantity</p>
                            @if (!string.IsNullOrWhiteSpace(ord.Address))
                            {
                                <p class="bill-order-address">@ShortAddress(ord.Address)</p>
                            }
                            <p class="bill-order-status">Order status: <span class="bill-order-status-val">@ord.Status</span></p>
                        }
                        else
                        {
                            <p class="bill-order-line text-muted">Order details loading or unavailable.</p>
                        }
                    </div>
                </div>
                <div class="bill-action">
                    <span class="bill-amount">Rs @bill.Amount</span>
                    <button type="button" class="btn-pay" @onclick="() => OpenPaymentModal(bill)">Pay Now</button>
                </div>
            </div>
        }
    }

    <div class="section-title mt-5">Payment History</div>
    <small class="text-muted d-block mb-3">Tap a row to view the full payment record for that bill.</small>
    @if (paidBills.Count == 0)
    {
        <p class="text-center text-muted py-3">No paid bills yet.</p>
    }
    else
    {
        @foreach (var bill in paidBills)
        {
            <div class="bill-card clickable-card history-card" @onclick="() => OpenReceiptModal(bill)">
                <div class="bill-info">
                    <div class="bill-icon icon-paid"><i class="fa-solid fa-check-circle"></i></div>
                    <div class="bill-details">
                        <h6>Supplier: @bill.SupplierName</h6>
                        <p class="bill-meta">
                            Order #@bill.OrderId • @(bill.PaymentMethod ?? "Method not set")
                        </p>
                        @if (OrderFor(bill.OrderId) is { } hOrd)
                        {
                            <p class="bill-order-line"><i class="fa-solid fa-droplet me-1"></i>@hOrd.ItemName × @hOrd.Quantity</p>
                        }
                    </div>
                </div>
                <div class="bill-action">
                    <span class="bill-amount text-muted">Rs @bill.Amount</span>
                    <span class="status-badge status-paid">Paid</span>
                    <span class="receipt-hint"><i class="fa-solid fa-receipt me-1"></i>View record</span>
                </div>
            </div>
        }
    }
</div>

@if (showPaymentModal && selectedBill != null)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="payment-modal" @onclick:stopPropagation="true">

            <div class="modal-header">
                <h4>Choose Payment</h4>
                <p>Order #@selectedBill.OrderId · @selectedBill.SupplierName</p>
                <div class="amount-tag">Rs @selectedBill.Amount</div>
            </div>

            @if (OrderFor(selectedBill.OrderId) is { } mOrd)
            {
                <div class="modal-order-box text-start mb-3">
                    <div class="modal-order-label">Your order</div>
                    <div class="text-white small">#@mOrd.Id — @mOrd.ItemName × @mOrd.Quantity</div>
                    @if (!string.IsNullOrWhiteSpace(mOrd.Address))
                    {
                        <div class="text-muted small mt-1">@mOrd.Address</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(mOrd.Phone))
                    {
                        <div class="text-muted small"><i class="fa-solid fa-phone me-1"></i>@mOrd.Phone</div>
                    }
                </div>
            }

            <div class="payment-options">
                <button type="button" class="pay-opt-btn jazz-btn" @onclick='() => ProcessPayment("JazzCash")'>
                    <div class="d-flex align-items-center gap-3">
                        <i class="fa-solid fa-mobile-screen text-danger"></i>
                        <span>JazzCash</span>
                    </div>
                    <i class="fa-solid fa-chevron-right small text-muted"></i>
                </button>

                <button type="button" class="pay-opt-btn card-btn" @onclick='() => ProcessPayment("Credit/Debit Card")'>
                    <div class="d-flex align-items-center gap-3">
                        <i class="fa-regular fa-credit-card text-primary"></i>
                        <span>Credit / Debit Card</span>
                    </div>
                    <i class="fa-solid fa-chevron-right small text-muted"></i>
                </button>
            </div>

            <button type="button" class="btn-close-modal" @onclick="CloseModal">Cancel Payment</button>
        </div>
    </div>
}

@if (showReceiptModal && receiptBill != null)
{
    <div class="modal-overlay receipt-modal-overlay" @onclick="CloseReceiptModal">
        <div class="payment-modal payment-modal-receipt text-start" @onclick:stopPropagation="true">
            <div class="receipt-modal-head d-flex align-items-start justify-content-between gap-2 mb-3">
                <div>
                    <h4 class="text-white mb-1"><i class="fa-solid fa-receipt me-2 text-neon"></i>Payment record</h4>
                    <p class="text-muted small mb-0">Paid — recorded when you completed payment on this page.</p>
                </div>
                <button type="button" class="btn-receipt-close" @onclick="CloseReceiptModal" aria-label="Close">✕</button>
            </div>

            <dl class="receipt-dl mb-0">
                <dt>Amount paid</dt>
                <dd class="text-white fw-bold">Rs @receiptBill.Amount</dd>
                <dt>Payment method</dt>
                <dd>@(receiptBill.PaymentMethod ?? "—")</dd>
                <dt>Supplier</dt>
                <dd>@receiptBill.SupplierName</dd>
                <dt>Bill / order</dt>
                <dd>Bill #@receiptBill.Id · Order #@receiptBill.OrderId</dd>
                <dt>Bill created</dt>
                <dd>@receiptBill.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</dd>
            </dl>

            @if (OrderFor(receiptBill.OrderId) is { } ro)
            {
                <div class="modal-order-box mt-3">
                    <div class="modal-order-label">What you ordered</div>
                    <ul class="receipt-order-list mb-0">
                        <li><span class="text-muted">Item</span> @ro.ItemName</li>
                        <li><span class="text-muted">Quantity</span> @ro.Quantity</li>
                        <li><span class="text-muted">Delivery address</span> @(string.IsNullOrWhiteSpace(ro.Address) ? "—" : ro.Address)</li>
                        <li><span class="text-muted">Phone</span> @(string.IsNullOrWhiteSpace(ro.Phone) ? "—" : ro.Phone)</li>
                        <li><span class="text-muted">Order status</span> @ro.Status</li>
                        <li><span class="text-muted">Order placed</span> @ro.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, hh:mm tt")</li>
                    </ul>
                </div>
            }
            else
            {
                <p class="text-muted small mt-3 mb-0">Linked order could not be loaded; amounts and method above still apply.</p>
            }

            <button type="button" class="btn-receipt-done" @onclick="CloseReceiptModal">Close</button>
        </div>
    </div>
}
