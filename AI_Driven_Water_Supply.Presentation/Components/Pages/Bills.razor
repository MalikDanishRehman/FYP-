@page "/bills"
@using AI_Driven_Water_Supply.Application.Interfaces

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">

<div class="glass-nav">
    <div class="d-flex align-items-center gap-3">
        <i class="fa-solid fa-arrow-left back-btn" @onclick="GoBack"></i>
        <div class="brand-logo">My Bills</div>
    </div>
</div>

<div class="container-bills">

    <div class="summary-grid">
        <div class="summary-card">
            <div class="summary-label">Total Unpaid</div>
            <div class="summary-val text-danger-neon">Rs @TotalUnpaid</div>
        </div>
        <div class="summary-card">
            <div class="summary-label">Last Paid</div>
            <div class="summary-val text-neon">Rs @LastPaidAmount</div>
        </div>
    </div>

    <div class="section-title">Pending Bills</div>
    @if (pendingBills.Count == 0)
    {
        <p class="text-center text-muted py-3">No pending bills.</p>
    }
    else
    {
        @foreach (var bill in pendingBills)
        {
            <div class="bill-card">
                <div class="bill-info">
                    <div class="bill-icon"><i class="fa-solid fa-bottle-water"></i></div>
                    <div class="bill-details">
                        <h6>Supplier: @bill.SupplierName</h6>
                        <p>Order #@bill.OrderId • @bill.CreatedAt.ToLocalTime().ToString("dd MMM")</p>
                    </div>
                </div>
                <div class="bill-action">
                    <span class="bill-amount">Rs @bill.Amount</span>
                    <button class="btn-pay" @onclick="() => OpenPaymentModal(bill)">Pay Now</button>
                </div>
            </div>
        }
    }

    <div class="section-title mt-5">Payment History</div>
    @foreach (var bill in paidBills)
    {
        <div class="bill-card history-card">
            <div class="bill-info">
                <div class="bill-icon icon-paid"><i class="fa-solid fa-check-circle"></i></div>
                <div class="bill-details">
                    <h6>Supplier: @bill.SupplierName</h6>
                    <p>Order #@bill.OrderId • @bill.CreatedAt.ToLocalTime().ToString("dd MMM")</p>
                </div>
            </div>
            <div class="bill-action">
                <span class="bill-amount text-muted">Rs @bill.Amount</span>
                <span class="status-badge status-paid">Paid</span>
            </div>
        </div>
    }
</div>

@if (showPaymentModal && selectedBill != null)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="payment-modal" @onclick:stopPropagation="true">

            <div class="modal-header">
                <h4>Choose Payment</h4>
                <p>Order #@selectedBill.OrderId</p>
                <div class="amount-tag">Rs @selectedBill.Amount</div>
            </div>

            <div class="payment-options">
                <button class="pay-opt-btn jazz-btn" @onclick='() => ProcessPayment("JazzCash")'>
                    <div class="d-flex align-items-center gap-3">
                        <i class="fa-solid fa-mobile-screen text-danger"></i>
                        <span>JazzCash</span>
                    </div>
                    <i class="fa-solid fa-chevron-right small text-muted"></i>
                </button>

                <button class="pay-opt-btn card-btn" @onclick='() => ProcessPayment("Credit/Debit Card")'>
                    <div class="d-flex align-items-center gap-3">
                        <i class="fa-regular fa-credit-card text-primary"></i>
                        <span>Credit / Debit Card</span>
                    </div>
                    <i class="fa-solid fa-chevron-right small text-muted"></i>
                </button>
            </div>

            <button class="btn-close-modal" @onclick="CloseModal">Cancel Payment</button>
        </div>
    </div>
}
