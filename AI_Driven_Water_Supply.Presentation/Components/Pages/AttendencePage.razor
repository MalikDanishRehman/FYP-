@page "/attendance"
@using AI_Driven_Water_Supply.Application.Interfaces
@using AI_Driven_Water_Supply.Domain.Entities
@using Supabase.Postgrest.Models
@rendermode InteractiveServer

<div class="page-container">

    <div class="container" style="max-width: 800px;">
        <div class="header-row">
            <h2 class="page-title"><i class="fa-solid fa-clipboard-user me-2"></i> Attendance</h2>
            <div class="text-end">
                <span class="d-block text-muted small">Today's Date</span>
                <span class="fw-bold">@todayDate</span>
            </div>
        </div>

        <button class="btn btn-outline-light w-100 mb-4 py-3" style="border-style: dashed;" @onclick="() => showAddModal = true">
            <i class="fa-solid fa-plus me-2"></i> Add New Worker
        </button>

        @if (isLoading)
        {
            <div class="text-center text-muted py-5">Loading workers...</div>
        }
        else if (workers.Count == 0)
        {
            <div class="text-center text-muted py-5">
                <i class="fa-solid fa-users-slash fs-1 mb-3 opacity-50"></i>
                <p>No workers found.</p>
            </div>
        }

        @foreach (var worker in workers)
        {
            <div class="worker-card" @onclick="() => OpenDetailModal(worker)">
                <div class="d-flex align-items-center">
                    <div class="avatar-circle">
                        @worker.Name.Substring(0, 1).ToUpper()
                    </div>
                    <div>
                        <h5 class="m-0 fw-bold">@worker.Name</h5>
                        <small class="text-muted">@worker.Role</small>
                    </div>
                </div>

                <div class="btn-action-group" @onclick:stopPropagation="true">
                    <button class="att-btn present @(worker.TodayStatus == "Present" ? "active" : "")"
                            @onclick='() => MarkStatus(worker, "Present")'>
                        <i class="fa-solid fa-check"></i>
                    </button>
                    <button class="att-btn absent @(worker.TodayStatus == "Absent" ? "active" : "")"
                            @onclick='() => MarkStatus(worker, "Absent")'>
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>
            </div>
        }
    </div>

</div>

@if (showAddModal)
{
    <div class="custom-modal-overlay">
        <div class="custom-modal">
            <button class="btn-close-custom" @onclick="() => showAddModal = false">&times;</button>
            <h4 class="mb-4">Add Worker</h4>

            <input type="text" class="form-control-dark" placeholder="Full Name" @bind="newWorker.Name" />
            <input type="text" class="form-control-dark" placeholder="Role (e.g. Helper)" @bind="newWorker.Role" />
            <input type="number" class="form-control-dark" placeholder="Monthly Salary (PKR)" @bind="newWorker.BaseSalary" />

            <button class="btn-neon" @onclick="SaveWorker">Save Record</button>
        </div>
    </div>
}

@if (showDetailModal)
{
    <div class="custom-modal-overlay">
        <div class="custom-modal text-center">
            <button class="btn-close-custom" @onclick="() => showDetailModal = false">&times;</button>

            <div class="avatar-circle mx-auto mb-3" style="width: 70px; height: 70px; font-size: 2rem;">
                @selectedWorker.Name.Substring(0, 1).ToUpper()
            </div>
            <h3>@selectedWorker.Name</h3>
            <p class="text-muted">@selectedWorker.Role</p>

            <div class="row g-2 mt-4">
                <div class="col-6">
                    <div class="p-3 border border-secondary rounded">
                        <small class="text-muted d-block">Days Present</small>
                        <h2 class="text-success m-0">@totalPresentDays</h2>
                    </div>
                </div>
                <div class="col-6">
                    <div class="p-3 border border-secondary rounded">
                        <small class="text-muted d-block">Base Salary</small>
                        <h4 class="text-white m-0">@selectedWorker.BaseSalary</h4>
                    </div>
                </div>
            </div>

            <div class="p-3 rounded mt-3" style="background: rgba(191, 255, 39, 0.1); border: 1px solid #BFFF27;">
                <small class="text-muted text-uppercase" style="letter-spacing:1px;">Calculated Salary</small>
                <h1 style="color: #BFFF27; font-weight: 800; margin: 0;">Rs @totalEarned</h1>
            </div>

            <button class="btn btn-outline-danger w-100 mt-4" @onclick="DeleteWorker">
                <i class="fa-solid fa-trash me-2"></i> Delete Record
            </button>
        </div>
    </div>
}
