@page "/chat/{OrderId:long}"
@using AI_Driven_Water_Supply.Presentation
@using Supabase.Postgrest.Models
@rendermode InteractiveServer

<div class="chat-wrapper">
    <div class="chat-container">

        <div class="chat-header">
            <div class="d-flex align-items-center gap-2">
                <button class="btn btn-sm btn-outline-secondary border-0 text-white" @onclick="GoBack">
                    <i class="fa-solid fa-arrow-left"></i>
                </button>

                <div>
                    <h5 class="m-0 fw-bold">@DisplayChatName</h5>
                    <small class="text-muted d-block" style="line-height:1;">
                        #@OrderId | <span class="badge @GetStatusColor(OrderStatus) p-1" style="font-size:0.6rem;">@OrderStatus</span>
                    </small>
                </div>
            </div>

            @if (AmISupplier && OrderStatus != "Completed" && OrderStatus != "Cancelled")
            {
                <div class="status-btn-group">
                    @if (OrderStatus == "Pending")
                    {
                        <button class="btn btn-success btn-xs" @onclick='() => UpdateStatus("Accepted")'><i class="fa-solid fa-check"></i></button>
                        <button class="btn btn-danger btn-xs" @onclick='() => UpdateStatus("Cancelled")'><i class="fa-solid fa-xmark"></i></button>
                    }
                    else if (OrderStatus == "Accepted")
                    {
                        <button class="btn btn-warning btn-xs text-dark" @onclick='() => UpdateStatus("Out for Delivery")'>Dispatch</button>
                    }
                    else if (OrderStatus == "Out for Delivery")
                    {
                        <button class="btn btn-info btn-xs text-dark" @onclick='() => UpdateStatus("Completed")'>Finish</button>
                    }
                </div>
            }
        </div>

        <div class="chat-body" id="chatList">
            @if (isLoading)
            {
                <div class="d-flex justify-content-center align-items-center h-100">
                    <div class="spinner-border text-success"></div>
                </div>
            }
            else if (messages.Count == 0)
            {
                <div class="d-flex flex-column justify-content-center align-items-center h-100 opacity-50">
                    <i class="fa-regular fa-comments fa-3x mb-3"></i>
                    <p>No messages yet.</p>
                </div>
            }
            else
            {
                @foreach (var msg in messages)
                {
                    @if (msg.SenderName == "System")
                    {
                        <div class="system-msg">@msg.Content</div>
                    }
                    else
                    {
                        <div class="message-bubble @(msg.SenderName == MyName ? "sent" : "received")">
                            @msg.Content
                            <span class="time-stamp">@msg.CreatedAt.ToLocalTime().ToString("hh:mm tt")</span>
                        </div>
                    }
                }
            }
        </div>

        <form class="chat-footer" @onsubmit="SendMessage" autocomplete="off">
            <input type="text" class="form-control bg-dark text-white border-secondary shadow-none"
                   style="border-radius: 20px;"
                   placeholder="Type a message..."
                   @bind="newMessageInput"
                   @bind:event="oninput" />

            <button type="submit" class="btn btn-success fw-bold rounded-circle"
                    style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;"
                    disabled="@(string.IsNullOrWhiteSpace(newMessageInput))">
                <i class="fa-solid fa-paper-plane"></i>
            </button>
        </form>

    </div>
</div>

<script>
    window.scrollToBottom = (id) => {
        const element = document.getElementById(id);
        if (element) {
            element.scrollTop = element.scrollHeight;
        }
    }
</script>