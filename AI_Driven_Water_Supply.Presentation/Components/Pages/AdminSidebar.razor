<div class="layout-wrapper">
    <aside class="sidebar @(isSidebarOpen ? "" : "closed")">
        <div style="display: flex; justify-content: space-between; align-items: center; padding-right: 15px;">
            <div class="brand-logo">
                <span class="brand-dot"></span> HYDROAI
            </div>
            <button class="hamburger-btn d-md-none" style="display: @(isSidebarOpen ? "block" : "none")" @onclick="ToggleSidebar">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <ul class="menu-list">
            <li class="menu-item">
                <NavLink class="menu-link" href="/AdminPage" Match="NavLinkMatch.All">
                    <i class="fa-solid fa-chart-pie"></i> Dashboard
                </NavLink>
            </li>
            <li class="menu-item">
                <NavLink class="menu-link" href="/VendorManagement">
                    <i class="fa-solid fa-store"></i> Vendors
                </NavLink>
            </li>
            <li class="menu-item">
                <NavLink class="menu-link" href="/UserManagement">
                    <i class="fa-solid fa-users"></i> Users
                </NavLink>
            </li>
            <li class="menu-item">
                <NavLink class="menu-link" href="/AdminDispute">
                    <i class="fa-solid fa-gavel"></i> Disputes
                </NavLink>
            </li>
            <li class="menu-item">
                <NavLink class="menu-link" href="/AdminSetting">
                    <i class="fa-solid fa-gear"></i> Settings
                </NavLink>
            </li>
        </ul>
    </aside>

    <main class="main-content">
        <header class="top-header">
            <div style="display:flex; align-items:center; gap: 15px;">
                <button class="hamburger-btn" @onclick="ToggleSidebar">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <span style="color: #666; font-weight: bold;">Admin Panel</span>
            </div>

            <div class="header-right">
                <span class="header-link" title="Dashboard"><i class="fa-solid fa-table-columns"></i> <span class="header-text">Dashboard</span></span>
                <span class="header-link" title="Profile"><i class="fa-regular fa-user"></i> <span class="header-text">Profile</span></span>
                <span class="header-link" style="color: #ff4d4d; cursor: pointer;" title="Logout" @onclick="HandleLogout">
                    <i class="fa-solid fa-arrow-right-from-bracket"></i> <span class="header-text">Logout</span>
                </span>
            </div>
        </header>

        <div class="content-body">
            @Body
        </div>
    </main>
</div>