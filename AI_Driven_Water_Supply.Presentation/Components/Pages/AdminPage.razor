@page "/AdminPage"
@using AI_Driven_Water_Supply.Application.Interfaces
@using AI_Driven_Water_Supply.Application.DTOs
@rendermode InteractiveServer
@layout AdminSidebar

<div class="welcome-section">
    <h1 class="welcome-title">Welcome back,<br> <span class="highlight">@UserName</span></h1>
    <p class="sub-text">Your AI-powered water supply monitoring dashboard</p>
</div>

<div class="action-row">
    <button type="button" class="btn-action" @onclick='() => StubNotConfigured("Email Config")'><i class="fa-regular fa-envelope"></i> Email Config</button>
    <button type="button" class="btn-action btn-primary-custom" @onclick='() => StubNotConfigured("Subscriptions")'><i class="fa-solid fa-crown"></i> Manage Subscriptions</button>
    <button type="button" class="btn-action" @onclick="RefreshAsync"><i class="fa-solid fa-rotate"></i> Refresh</button>
</div>

<div class="stats-container">
    <div class="stat-box">
        <span class="stat-label">Total Revenue</span>
        <h2 class="stat-value">
            @if (isLoadingMetrics) { <text>…</text> }
            else { <text>Rs @(metrics?.TotalRevenuePkr.ToString("N0") ?? "0")</text> }
        </h2>
        <span class="stat-sub"><i class="fa-solid fa-wallet"></i> Sum of order totals</span>
        <i class="fa-solid fa-wallet stat-icon"></i>
    </div>

    <div class="stat-box">
        <span class="stat-label">Active Vendors</span>
        <h2 class="stat-value">
            @if (isLoadingMetrics) { <text>…</text> }
            else { <text>@(metrics?.ActiveVendors ?? 0)</text> }
        </h2>
        <span class="stat-sub" style="color:#2ecc71; background:rgba(46,204,113,0.1)">Providers (active)</span>
        <i class="fa-solid fa-store stat-icon"></i>
    </div>

    <div class="stat-box">
        <span class="stat-label">Success Rate</span>
        <h2 class="stat-value">
            @if (isLoadingMetrics) { <text>…</text> }
            else { <text>@(metrics?.SuccessRatePercent.ToString("0.#") ?? "0")%</text> }
        </h2>
        <span class="stat-sub"><i class="fa-solid fa-check"></i> Delivered / completed vs all orders</span>
        <i class="fa-solid fa-chart-line stat-icon"></i>
    </div>

    <div class="stat-box">
        <span class="stat-label">Open disputes</span>
        <h2 class="stat-value">
            @if (isLoadingMetrics) { <text>…</text> }
            else { <text>@(metrics?.PendingDisputes ?? 0)</text> }
        </h2>
        <span class="stat-sub" style="color:#ff4d4d; background:rgba(255,77,77,0.1)">Pending orders: @(metrics?.PendingOrders ?? 0)</span>
        <i class="fa-solid fa-triangle-exclamation stat-icon"></i>
    </div>
</div>

<div class="table-section">
    <h4 style="margin: 0 0 20px 0; color: white;">Recent Transactions</h4>

    <div class="filter-bar">
        <input type="text" class="filter-input" placeholder="Status (e.g. Pending)" @bind="statusFilter" />
        <input type="text" class="filter-input" placeholder="Search Order ID" @bind="searchOrderId" />
        <button type="button" class="btn-action" @onclick="ApplyFiltersAsync">Apply</button>
        <button type="button" class="btn-action" @onclick="ClearFiltersAsync">Clear Filters</button>
    </div>

    <div class="table-responsive">
        <table class="table-dark">
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Vendor</th>
                    <th>Amount</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (isLoadingOrders)
                {
                    <tr><td colspan="5" style="text-align:center;color:#888;">Loading orders…</td></tr>
                }
                else if (!recentOrders.Any())
                {
                    <tr><td colspan="5" style="text-align:center;color:#888;">No orders found.</td></tr>
                }
                else
                {
                    @foreach (var o in recentOrders)
                    {
                        var st = (o.Status ?? "").Trim();
                        var lower = st.ToLowerInvariant();
                        var dotClass = lower is "pending" or "processing" ? "st-pending" : "st-completed";
                        <tr>
                            <td>#@o.Id</td>
                            <td>@o.ConsumerName</td>
                            <td>@o.SupplierName</td>
                            <td>Rs @o.TotalPrice.ToString("N0")</td>
                            <td><span class="status-dot @dotClass"></span>@o.Status</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
