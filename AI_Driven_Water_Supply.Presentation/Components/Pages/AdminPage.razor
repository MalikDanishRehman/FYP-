@page "/AdminPage"
@using AI_Driven_Water_Supply.Application.Interfaces
@using AI_Driven_Water_Supply.Domain.Entities
@using Supabase.Postgrest.Models
@using Supabase.Postgrest.Attributes
@rendermode InteractiveServer
@layout AdminSidebar

<div class="welcome-section">
    <h1 class="welcome-title">Welcome back,<br> <span class="highlight">@UserName</span></h1>
    <p class="sub-text">Your AI-powered water supply monitoring dashboard</p>
</div>

<div class="action-row">
    <button class="btn-action"><i class="fa-regular fa-envelope"></i> Email Config</button>
    <button class="btn-action btn-primary-custom"><i class="fa-solid fa-crown"></i> Manage Subscriptions</button>
    <button class="btn-action"><i class="fa-solid fa-rotate"></i> Refresh</button>
</div>

<div class="stats-container">
    <div class="stat-box">
        <span class="stat-label">Total Revenue</span>
        <h2 class="stat-value">Rs 1.2M</h2>
        <span class="stat-sub"><i class="fa-solid fa-arrow-trend-up"></i> +12% this month</span>
        <i class="fa-solid fa-wallet stat-icon"></i>
    </div>

    <div class="stat-box">
        <span class="stat-label">Active Vendors</span>
        <h2 class="stat-value">45</h2>
        <span class="stat-sub" style="color:#2ecc71; background:rgba(46,204,113,0.1)">Online</span>
        <i class="fa-solid fa-store stat-icon"></i>
    </div>

    <div class="stat-box">
        <span class="stat-label">Success Rate</span>
        <h2 class="stat-value">98.5%</h2>
        <span class="stat-sub"><i class="fa-solid fa-check"></i> Processing</span>
        <i class="fa-solid fa-chart-line stat-icon"></i>
    </div>

    <div class="stat-box">
        <span class="stat-label">Issues Reported</span>
        <h2 class="stat-value">3</h2>
        <span class="stat-sub" style="color:#ff4d4d; background:rgba(255,77,77,0.1)">Action Required</span>
        <i class="fa-solid fa-triangle-exclamation stat-icon"></i>
    </div>
</div>

<div class="table-section">
    <h4 style="margin: 0 0 20px 0; color: white;">Recent Transactions</h4>

    <div class="filter-bar">
        <input type="text" class="filter-input" placeholder="All Status">
        <input type="text" class="filter-input" placeholder="Pick a date">
        <input type="text" class="filter-input" placeholder="Search Order ID">
        <button class="btn-action">Clear Filters</button>
    </div>

    <div class="table-responsive">
        <table class="table-dark">
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Vendor</th>
                    <th>Amount</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>#ORD-8821</td>
                    <td>Ali Khan</td>
                    <td>Aqua Pure</td>
                    <td>Rs 500</td>
                    <td><span class="status-dot st-completed"></span>Delivered</td>
                </tr>
                <tr>
                    <td>#ORD-8822</td>
                    <td>Sara Ahmed</td>
                    <td>Blue Water</td>
                    <td>Rs 1200</td>
                    <td><span class="status-dot st-pending"></span>Pending</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@code {
    private bool isSidebarOpen = true;

    private void ToggleSidebar()
    {
        isSidebarOpen = !isSidebarOpen;
    }
}