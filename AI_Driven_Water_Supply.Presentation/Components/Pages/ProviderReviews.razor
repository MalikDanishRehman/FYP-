@page "/provider-reviews"
@using Supabase.Postgrest.Attributes
@using Supabase.Postgrest.Models
@using AI_Driven_Water_Supply.Application.Interfaces
@rendermode InteractiveServer

<div class="container mt-4 pb-5">
    <button class="btn btn-outline-secondary mb-4" @onclick='() => Nav.NavigateTo("/ProviderDashboard")'>
        <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
    </button>

    @if (isLoading)
    {
        <div class="text-center text-white mt-5">
            <div class="spinner-border text-warning" role="status"></div>
            <p class="mt-2 text-muted">Loading...</p>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card bg-dark text-white border-secondary shadow-lg">
                    <div class="card-body text-center p-4">
                        <h5 class="text-muted mb-3">Overall Rating</h5>
                        <h1 class="display-1 fw-bold text-white mb-0">@averageRating.ToString("0.0")</h1>
                        <div class="mb-2 fs-4 text-warning">
                            @((MarkupString)GetStarHtml(averageRating))
                        </div>
                        <p class="text-muted small">Based on @totalReviews reviews</p>
                        <hr class="border-secondary my-4" />

                        <div class="text-start">
                            @for (int i = 5; i >= 1; i--)
                            {
                                var count = starCounts.ContainsKey(i) ? starCounts[i] : 0;
                                var percentage = totalReviews > 0 ? (int)((double)count / totalReviews * 100) : 0;

                                <div class="d-flex align-items-center mb-2">
                                    <span class="text-muted me-2 small" style="width: 15px;">@i</span>
                                    <i class="fa-solid fa-star text-warning fs-6 me-2"></i>
                                    <div class="progress flex-grow-1" style="height: 6px; background-color: #333;">
                                        <div class="progress-bar bg-warning" role="progressbar"
                                             style="width: @percentage%"></div>
                                    </div>
                                    <span class="text-muted ms-2 small" style="width: 30px; text-align: right;">@count</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-8">
                <h4 class="text-white mb-3 border-bottom border-secondary pb-2">Recent Customer Feedback</h4>

                @if (reviewsList == null || reviewsList.Count == 0)
                {
                    <div class="alert alert-secondary bg-dark border-secondary text-white">
                        <i class="fa-regular fa-face-meh me-2"></i> No reviews received yet.
                        <br />
                        <small class="text-muted">Debug: List is empty.</small>
                    </div>
                }
                else
                {
                    <div class="reviews-container">
                        @foreach (var review in reviewsList)
                        {
                            <div class="card bg-dark text-white border-secondary mb-3">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center fw-bold text-white"
                                                 style="width: 45px; height: 45px; font-size: 18px;">
                                                @(!string.IsNullOrEmpty(review.ConsumerName) ? review.ConsumerName.Substring(0, 1).ToUpper() : "U")
                                            </div>
                                            <div>
                                                <h6 class="m-0 fw-bold">@(review.ConsumerName ?? "Customer")</h6>
                                                <div class="text-warning small">
                                                    @((MarkupString)GetStarHtml(review.Rating))
                                                </div>
                                            </div>
                                        </div>
                                        <small class="text-muted">@review.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</small>
                                    </div>
                                    <p class="mt-3 text-light">
                                        @if (string.IsNullOrWhiteSpace(review.Comment))
                                        {
                                            <em class="text-muted">No written comment.</em>
                                        }
                                        else
                                        {
                                            @review.Comment
                                        }
                                    </p>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>