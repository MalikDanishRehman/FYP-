@page "/get-started"
@rendermode InteractiveServer

<div class="selection-container">
    <div class="text-center mb-5 fade-in">
        <h1 class="brand-title">💧 HydroAI</h1>
        @if (!showServices)
        {
            <p class="text-muted">Choose how you want to join us</p>
        }
        else
        {
            <p class="text-muted">What type of water supply do you provide?</p>
        }
    </div>

    @if (!showServices)
    {
        <div class="cards-wrapper fade-in">
            <div class="role-card consumer" @onclick='() => SelectRole("Consumer")'>
                <div class="icon-circle">
                    <i class="bi bi-cart-check-fill"></i>
                </div>
                <h3>I want to Buy Water</h3>
                <p>Order water tankers or bottles for your home.</p>
                <div class="arrow-icon"><i class="bi bi-arrow-right"></i></div>
            </div>

            <div class="role-card provider" @onclick='() => ShowServiceSelection()'>
                <div class="icon-circle">
                    <i class="bi bi-truck"></i>
                </div>
                <h3>I want to Sell Water</h3>
                <p>Manage orders, delivery & grow your business.</p>
                <div class="arrow-icon"><i class="bi bi-arrow-right"></i></div>
            </div>
        </div>
    }
    else
    {
        <div class="service-wrapper fade-in">

            <div class="service-card @(selectedServices.Contains("Bottle") ? "active" : "")"
                 @onclick='() => ToggleService("Bottle")'>
                <i class="bi bi-droplet-half icon-main"></i>
                <h4>1 Litre Bottles</h4>
                <div class="check-icon"><i class="bi bi-check-circle-fill"></i></div>
            </div>

            <div class="service-card @(selectedServices.Contains("Plant") ? "active" : "")"
                 @onclick='() => ToggleService("Plant")'>
                <i class="bi bi-shop icon-main"></i>
                <h4>Plant Supply</h4>
                <div class="check-icon"><i class="bi bi-check-circle-fill"></i></div>
            </div>

            <div class="service-card @(selectedServices.Contains("Tanker") ? "active" : "")"
                 @onclick='() => ToggleService("Tanker")'>
                <i class="bi bi-truck-front-fill icon-main"></i>
                <h4>Water Tankers</h4>
                <div class="check-icon"><i class="bi bi-check-circle-fill"></i></div>
            </div>

        </div>

        <div class="mt-5 d-flex gap-3">
            <button class="btn btn-outline-light px-4 py-2 rounded-pill" @onclick="GoBack">Back</button>
            <button class="btn btn-gradient px-5 py-2 rounded-pill" @onclick="FinalizeProviderSignup" disabled="@(selectedServices.Count == 0)">
                Continue <i class="bi bi-arrow-right ms-2"></i>
            </button>
        </div>
    }

    <div class="mt-5 text-center">
        <a href="/login" class="text-decoration-none text-muted small hover-link">Already have an account? <span class="text-info">Login</span></a>
    </div>
</div>