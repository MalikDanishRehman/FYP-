@page "/VendorManagement"
@using AI_Driven_Water_Supply.Application.Interfaces
@using AI_Driven_Water_Supply.Domain.Entities
@rendermode InteractiveServer
@layout AdminSidebar

<div class="page-header">
    <div class="header-title">
        <h2>Vendor <span>Management</span></h2>
        <small style="color: #666;">Manage your water suppliers and their status</small>
    </div>

    <div class="search-wrapper">
        <i class="fa-solid fa-search search-icon"></i>
        <input type="text" class="custom-input" placeholder="Search vendor by name..." @bind="searchTerm" @bind:event="oninput">
    </div>
</div>

<div class="table-card">
    <table class="vendor-table">
        <thead>
            <tr>
                <th>Vendor Profile</th>
                <th>Shop Location</th>
                <th>Performance</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (IsLoading)
            {
                <tr>
                    <td colspan="5" style="text-align: center; padding: 20px;">
                        <span style="color: #BFFF27;">Loading vendors from database...</span>
                    </td>
                </tr>
            }
            else if (!FilteredVendors.Any())
            {
                <tr>
                    <td colspan="5" style="text-align: center; padding: 20px;">
                        No vendors (Providers) found.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var vendor in FilteredVendors)
                {
                    var st = string.IsNullOrEmpty(vendor.AccountStatus) ? "active" : vendor.AccountStatus;
                    var isBanned = string.Equals(st, "banned", StringComparison.OrdinalIgnoreCase);
                    <tr>
                        <td>
                            <div class="vendor-profile">
                                <div class="avatar-box" style="background: linear-gradient(135deg, #3498db, #2980b9);">
                                    @(string.IsNullOrEmpty(vendor.Username) ? "V" : vendor.Username.Substring(0, 1).ToUpper())
                                </div>
                                <div class="vendor-details">
                                    <h4>@(string.IsNullOrEmpty(vendor.Username) ? "Unknown" : vendor.Username)</h4>
                                    <p style="font-size: 0.8rem; color: #888;">ID: @IdPreview(vendor.Id)</p>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span style="display:block; color:#eee;">@(string.IsNullOrEmpty(vendor.Location) ? "Location not updated" : vendor.Location)</span>
                        </td>
                        <td>
                            <div class="rating-box">
                                <i class="fa-solid fa-star" style="color: gold;"></i>
                                <span class="rating-text">(@(vendor.Rating ?? 0.0))</span>
                            </div>
                        </td>
                        <td>
                            @if (isBanned)
                            {
                                <span class="status-badge" style="background:#c0392b;">Banned</span>
                            }
                            else
                            {
                                <span class="status-badge badge-verified">@st</span>
                            }
                        </td>
                        <td>
                            <div class="action-group">
                                <button type="button" class="btn-icon" title="View Profile" @onclick="() => ViewVendorStub(vendor)"><i class="fa-regular fa-eye"></i></button>
                                <button type="button" class="btn-icon btn-ban" title="@(isBanned ? "Reactivate" : "Ban")" @onclick="@(async () => await ToggleBanAsync(vendor))"><i class="fa-solid @(isBanned ? "fa-user-check" : "fa-ban")"></i></button>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
