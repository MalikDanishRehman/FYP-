@page "/AdminSetting"
@using AI_Driven_Water_Supply.Application.Interfaces
@rendermode InteractiveServer
@layout AdminSidebar

<div class="page-header">
    <h2>Settings</h2>
    <p>Manage your profile details and preferences.</p>
</div>

@if (isLoading)
{
    <p style="color:#888;">Loading…</p>
}
else
{
<div class="settings-grid">

    <div class="setting-card">
        <div class="card-header">
            <i class="fa-solid fa-user card-icon"></i>
            <h3 class="card-title">My Profile</h3>
        </div>

        <div class="profile-section">
            <div class="avatar-circle">@AvatarLetter()</div>
            <div class="profile-text">
                <h4>@(string.IsNullOrEmpty(adminName) ? "Admin" : adminName)</h4>
                <span>Super Administrator</span>
            </div>
        </div>

        <div class="form-group">
            <label>Full Name</label>
            <input type="text" class="form-control-dark" @bind="adminName" placeholder="Enter your name" />
        </div>

        <div class="form-group">
            <label>Email Address</label>
            <input type="email" class="form-control-dark" value="@adminEmail" disabled placeholder="admin@example.com" />
        </div>

        <div class="form-group">
            <label>Phone</label>
            <input type="text" class="form-control-dark" @bind="adminPhone" placeholder="+92 300 1234567" />
        </div>

        <button type="button" class="btn-save" @onclick="SaveProfileAsync">
            <i class="fa-solid fa-check"></i> Update Profile
        </button>
    </div>

    <div class="setting-card">
        <div class="card-header">
            <i class="fa-solid fa-shield-halved card-icon"></i>
            <h3 class="card-title">Security</h3>
        </div>

        <div class="form-group">
            <label>New Password</label>
            <input type="password" class="form-control-dark" placeholder="New strong password" @bind="newPassword" />
        </div>

        <div class="form-group">
            <label>Confirm Password</label>
            <input type="password" class="form-control-dark" placeholder="Repeat new password" @bind="confirmPassword" />
        </div>

        <button type="button" class="btn-save" style="background:transparent; border:1px solid #BFFF27; color:#BFFF27;" @onclick="ChangePasswordAsync">
            <i class="fa-solid fa-key"></i> Change Password
        </button>
    </div>

    <div class="setting-card">
        <div class="card-header">
            <i class="fa-solid fa-bell card-icon"></i>
            <h3 class="card-title">Notifications</h3>
        </div>

        <div class="toggle-row">
            <div>
                <div style="color:white; font-size:0.95rem;">Email Alerts</div>
                <small style="color:#666;">Get emails for new disputes.</small>
            </div>
            <label class="switch">
                <input type="checkbox" @bind="emailAlerts">
                <span class="slider"></span>
            </label>
        </div>

        <div class="toggle-row">
            <div>
                <div style="color:white; font-size:0.95rem;">Desktop Notifications</div>
                <small style="color:#666;">Popups when vendors sign up.</small>
            </div>
            <label class="switch">
                <input type="checkbox" @bind="desktopNotifications">
                <span class="slider"></span>
            </label>
        </div>

        <div class="toggle-row">
            <div>
                <div style="color:white; font-size:0.95rem;">Monthly Reports</div>
                <small style="color:#666;">Receive auto-generated PDF reports.</small>
            </div>
            <label class="switch">
                <input type="checkbox" @bind="monthlyReports">
                <span class="slider"></span>
            </label>
        </div>

        <div class="toggle-row">
            <div>
                <div style="color:white; font-size:0.95rem;">Sound Effects</div>
                <small style="color:#666;">Play sound on new orders.</small>
            </div>
            <label class="switch">
                <input type="checkbox" @bind="soundEffects">
                <span class="slider"></span>
            </label>
        </div>

        <button type="button" class="btn-save" @onclick="SavePreferencesAsync">
            <i class="fa-solid fa-floppy-disk"></i> Save Preferences
        </button>
    </div>

</div>
}
