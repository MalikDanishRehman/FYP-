@page "/ProviderDashboard"
@using AI_Driven_Water_Supply.Application.Interfaces
@using Supabase.Gotrue
@using AI_Driven_Water_Supply.Presentation
@using Supabase.Postgrest.Attributes
@using Supabase.Postgrest.Models
@rendermode InteractiveServer

<link rel="stylesheet" href="css/provider-dashboard-page.css" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="page-wrapper provider-dashboard-page">
    <div class="container">

        <div class="header-section">
        
            <h2 class="welcome-text mb-2">Hi, <span>@UserName</span>! 👋</h2>
            <p class="text-muted">Here's your business overview.</p>
            <div class="revenue-card">
                <span class="revenue-label"><i class="fa-solid fa-chart-line me-2 text-success"></i> Total Estimated Revenue</span>
                <h1 class="revenue-amount">Rs @totalRevenue</h1>
                <p class="text-muted mb-0 small">Updated just now</p>
            </div>
        </div>

        <div class="ai-dashboard-section">
            <div class="ai-header">
                <div class="ai-title">
                    <h4><i class="fa-solid fa-wand-magic-sparkles text-warning"></i> Demand AI</h4>
                    <p>Forecast based on weather & history</p>
                </div>
                <div class="time-selector">
                    <button class="time-btn @(activeTab == "Tomorrow" ? "active" : "")" @onclick='() => SwitchTab("Tomorrow")'>Tomorrow</button>
                    <button class="time-btn @(activeTab == "Week" ? "active" : "")" @onclick='() => SwitchTab("Week")'>Next 7 Days</button>
                    <button class="time-btn @(activeTab == "Month" ? "active" : "")" @onclick='() => SwitchTab("Month")'>Month</button>
                </div>
            </div>

            <div class="chart-wrapper">
                <canvas id="aiPredictionChart"></canvas>
            </div>

            <div class="ai-insight">
                <span class="insight-badge">AI ALERT</span>
                <span id="ai-text">High demand expected tomorrow around 2:00 PM.</span>
            </div>
        </div>

        <div class="stats-section">
            <p class="stats-hint text-muted small mb-2">Tap <strong>Active Orders</strong> or <strong>Completed</strong> for your lists. Tap any row to open chat for that order.</p>
            <div class="stats-grid">
                <button type="button"
                        class="stat-card stat-card--interactive @(expandedStat == "active" ? "stat-card--expanded" : "")"
                        @onclick='() => ToggleStatDetail("active")'
                        aria-expanded="@(expandedStat == "active")">
                    <div class="stat-value text-primary">@activeOrdersCount</div>
                    <div class="stat-label">Active Orders</div>
                    <span class="stat-chevron" aria-hidden="true"><i class="fa-solid fa-chevron-down"></i></span>
                </button>
                <button type="button"
                        class="stat-card stat-card--interactive @(expandedStat == "completed" ? "stat-card--expanded" : "")"
                        @onclick='() => ToggleStatDetail("completed")'
                        aria-expanded="@(expandedStat == "completed")">
                    <div class="stat-value text-warning">@completedCount</div>
                    <div class="stat-label">Completed</div>
                    <span class="stat-chevron" aria-hidden="true"><i class="fa-solid fa-chevron-down"></i></span>
                </button>
            </div>

            @if (expandedStat == "active")
            {
                <div class="stat-detail-panel stat-detail-panel--primary" role="region" aria-label="Active orders list">
                    <h3 class="stat-detail-title">Active orders</h3>
                    <p class="stat-detail-subhint mb-3">Tap an order to open its chat with the customer.</p>
                    @if (activeOrdersList.Count == 0)
                    {
                        <p class="stat-detail-text mb-0">No active orders right now. New requests will show up here.</p>
                    }
                    else
                    {
                        <div class="stat-order-stack">
                            @foreach (var order in activeOrdersList)
                            {
                                <button type="button"
                                        class="stat-order-row stat-order-row--accent-primary"
                                        @onclick="@(() => OpenChatForOrder(order.Id))"
                                        title="Open chat for this order">
                                    <div class="stat-order-row-body">
                                        <div class="stat-order-row-top">
                                            <span class="stat-order-name">@(string.IsNullOrWhiteSpace(order.ConsumerName) ? "Customer" : order.ConsumerName)</span>
                                            <span class="stat-order-status @OrderStatusCssClass(order.Status)">@order.Status</span>
                                        </div>
                                        <div class="stat-order-meta-line">
                                            <span class="stat-order-chip">#@order.Id</span>
                                            @if (!string.IsNullOrWhiteSpace(order.ItemName))
                                            {
                                                <span class="stat-order-chip stat-order-chip--muted">@order.ItemName</span>
                                            }
                                        </div>
                                        <div class="stat-order-meta-line stat-order-meta-line--dense">
                                            <span>Qty @order.Quantity</span>
                                            <span class="stat-order-dot" aria-hidden="true"></span>
                                            <span class="stat-order-price">Rs @order.TotalPrice</span>
                                            <span class="stat-order-dot" aria-hidden="true"></span>
                                            <span>@order.CreatedAt.ToLocalTime().ToString("MMM d, h:mm tt")</span>
                                        </div>
                                    </div>
                                    <div class="stat-order-chat-action" aria-hidden="true">
                                        <i class="fa-regular fa-comment-dots stat-order-chat-action-icon"></i>
                                        <span class="stat-order-chat-action-label">Chat</span>
                                    </div>
                                </button>
                            }
                        </div>
                    }
                </div>
            }
            else if (expandedStat == "completed")
            {
                <div class="stat-detail-panel stat-detail-panel--warning" role="region" aria-label="Completed orders list">
                    <h3 class="stat-detail-title">Completed orders</h3>
                    <p class="stat-detail-subhint mb-3">Tap a row to open chat and view the full thread for that delivery.</p>
                    @if (completedOrdersList.Count == 0)
                    {
                        <p class="stat-detail-text mb-0">No completed orders yet. Finished jobs will appear here.</p>
                    }
                    else
                    {
                        <div class="stat-order-stack">
                            @foreach (var order in completedOrdersList)
                            {
                                <button type="button"
                                        class="stat-order-row stat-order-row--accent-warning"
                                        @onclick="@(() => OpenChatForOrder(order.Id))"
                                        title="Open chat for this order">
                                    <div class="stat-order-row-body">
                                        <div class="stat-order-row-top">
                                            <span class="stat-order-name">@(string.IsNullOrWhiteSpace(order.ConsumerName) ? "Customer" : order.ConsumerName)</span>
                                            <span class="stat-order-status @OrderStatusCssClass(order.Status)">@order.Status</span>
                                        </div>
                                        <div class="stat-order-meta-line">
                                            <span class="stat-order-chip">#@order.Id</span>
                                            @if (!string.IsNullOrWhiteSpace(order.ItemName))
                                            {
                                                <span class="stat-order-chip stat-order-chip--muted">@order.ItemName</span>
                                            }
                                        </div>
                                        <div class="stat-order-meta-line stat-order-meta-line--dense">
                                            <span>Qty @order.Quantity</span>
                                            <span class="stat-order-dot" aria-hidden="true"></span>
                                            <span class="stat-order-price">Rs @order.TotalPrice</span>
                                            <span class="stat-order-dot" aria-hidden="true"></span>
                                            <span>@order.CreatedAt.ToLocalTime().ToString("MMM d, h:mm tt")</span>
                                        </div>
                                    </div>
                                    <div class="stat-order-chat-action" aria-hidden="true">
                                        <i class="fa-regular fa-comment-dots stat-order-chat-action-icon"></i>
                                        <span class="stat-order-chat-action-label">Chat</span>
                                    </div>
                                </button>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<script>
    let aiChart;

    function renderPredictionChart(data) {
        const ctx = document.getElementById('aiPredictionChart');
        if (!ctx) return;

        const g = ctx.getContext('2d');
        const gradPast = g.createLinearGradient(0, 0, 0, 400);
        gradPast.addColorStop(0, 'rgba(191, 255, 39, 0.4)'); gradPast.addColorStop(1, 'rgba(191, 255, 39, 0)');
        const gradFuture = g.createLinearGradient(0, 0, 0, 400);
        gradFuture.addColorStop(0, 'rgba(255, 189, 74, 0.5)'); gradFuture.addColorStop(1, 'rgba(255, 189, 74, 0)');

        let labels = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
        let pastData = [12, 15, 10, 14, 18, null, null];
        let futureData = [null, null, null, null, 18, 22, 25];
        if (data && data.week) {
            labels = data.week.labels || labels;
            pastData = data.week.pastData || pastData;
            futureData = data.week.futureData || futureData;
        }

        const config = {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    { label: 'History', data: pastData, borderColor: '#BFFF27', backgroundColor: gradPast, fill: true, tension: 0.4, pointRadius: 4 },
                    { label: 'Prediction', data: futureData, borderColor: '#FFBD4A', backgroundColor: gradFuture, fill: true, tension: 0.4, borderDash: [5, 5], pointRadius: 4 }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { x: { grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: '#888' } }, y: { display: false } }
            }
        };
        aiChart = new Chart(ctx, config);
        var el = document.getElementById('ai-text');
        if (el && data && data.week && data.week.note) el.innerText = data.week.note;
    }

    function updatePredictionChart(mode, data) {
        if (!aiChart) return;

        let labels, pastData, futureData, note;
        const modeKey = mode === 'Tomorrow' ? 'tomorrow' : mode === 'Month' ? 'month' : 'week';
        const m = data && data[modeKey];

        if (m && m.labels) {
            labels = m.labels;
            pastData = m.pastData || [];
            futureData = m.futureData || [];
            note = m.note || '';
        } else {
            if (mode === 'Tomorrow') {
                labels = ['8 AM', '10 AM', '12 PM', '2 PM', '4 PM', '6 PM', '8 PM'];
                pastData = [null, null, null, null, null, null, null];
                futureData = [5, 12, 25, 30, 20, 15, 10];
                note = "Peak demand expected at 2:00 PM due to temperature rise.";
            } else if (mode === 'Week') {
                labels = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
                pastData = [12, 15, 10, 14, 18, null, null];
                futureData = [null, null, null, null, 18, 22, 25];
                note = "Weekend demand surge expected (Upcoming Wedding Season).";
            } else {
                labels = ['Week 1', 'Week 2', 'Week 3', 'Week 4'];
                pastData = [150, 180, null, null];
                futureData = [null, 180, 210, 240];
                note = "Overall 20% growth projected for next month.";
            }
        }

        aiChart.data.labels = labels;
        aiChart.data.datasets[0].data = pastData;
        aiChart.data.datasets[1].data = futureData;
        aiChart.update();
        var el = document.getElementById('ai-text');
        if (el) el.innerText = note;
    }

    window.renderPredictionChart = renderPredictionChart;
    window.updatePredictionChart = updatePredictionChart;
</script>