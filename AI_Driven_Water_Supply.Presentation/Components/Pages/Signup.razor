@page "/signup"
@using System.ComponentModel.DataAnnotations
@using AI_Driven_Water_Supply.Application.Interfaces
@using Supabase.Postgrest.Attributes
@using Supabase.Postgrest.Models
@using Microsoft.AspNetCore.WebUtilities

@rendermode InteractiveServer

<div class="auth-wrapper">
    <EditForm Model="@signupModel" OnValidSubmit="HandleSignup" FormName="SignupForm">
        <DataAnnotationsValidator />

        <div class="auth-card">
            <h2 class="mb-2 fw-bold" style="font-size: 2rem;">Sign Up</h2>

            <div class="role-badge">Joining as: <span class="text-info">@signupModel.Role</span></div>

            @if (!string.IsNullOrEmpty(message))
            {
                <div class="alert @(isSuccess ? "alert-success" : "alert-danger") py-2 small mb-3">
                    @message
                </div>
            }

            <div class="mb-3 text-start">
                <label class="form-label">Email</label>
                <InputText @bind-Value="signupModel.Email" class="form-control" type="email" placeholder="Enter email" />
                <ValidationMessage For="@(() => signupModel.Email)" class="text-danger small" />
            </div>

            <div class="mb-3 text-start">
                <label class="form-label">Password</label>
                <div class="password-wrapper">
                    <InputText @bind-Value="signupModel.Password" class="form-control pr-icon" type="@passwordInputType" placeholder="••••••••" />
                    <i class="bi @passwordIcon password-toggle-icon" @onclick="TogglePasswordVisibility"></i>
                </div>
                <ValidationMessage For="@(() => signupModel.Password)" class="text-danger small" />
            </div>

            <button type="submit" class="btn-neon" disabled="@isLoading">
                @if (isLoading)
                {
                    <span>Processing...</span>
                }
                else
                {
                    <span>Sign Up</span>
                }
            </button>

            <div class="link-text">
                Already have an account? <a href="/login">Login</a> <br>
                <a href="/get-started" class="text-muted small mt-2 d-block">Change Role</a>
            </div>
        </div>
    </EditForm>
</div>