@page "/AdminDispute"
@using AI_Driven_Water_Supply.Application.Interfaces
@using AI_Driven_Water_Supply.Application.DTOs
@rendermode InteractiveServer
@layout AdminSidebar

<div class="page-header">
    <div class="header-title">
        <h2>Dispute <span>Center</span></h2>
        <small style="color:#666;">Manage and resolve customer complaints</small>
    </div>

    <div class="filter-tabs">
        <button type="button" class="tab-btn @(activeTab == "All" ? "active" : "")" @onclick='async () => { activeTab = "All"; await ReloadAsync(); }'>All Tickets</button>
        <button type="button" class="tab-btn @(activeTab == "Pending" ? "active" : "")" @onclick='async () => { activeTab = "Pending"; await ReloadAsync(); }'>Pending</button>
        <button type="button" class="tab-btn @(activeTab == "Resolved" ? "active" : "")" @onclick='async () => { activeTab = "Resolved"; await ReloadAsync(); }'>Resolved</button>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-info">
            <p>Tickets (loaded)</p>
            <h3>@tickets.Count</h3>
        </div>
        <div class="stat-icon" style="background: rgba(255,255,255,0.05); color: white;">
            <i class="fa-solid fa-ticket"></i>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <p>Pending (system)</p>
            <h3>@pendingFromMetrics</h3>
        </div>
        <div class="stat-icon" style="background: rgba(255, 165, 2, 0.1); color: #ffa502;">
            <i class="fa-solid fa-clock"></i>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-info">
            <p>Critical (loaded)</p>
            <h3>@tickets.Count(t => t.Priority == "High")</h3>
        </div>
        <div class="stat-icon" style="background: rgba(231, 76, 60, 0.1); color: #e74c3c;">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
    </div>
</div>

<div class="table-card">
    @if (isLoading)
    {
        <p style="padding:20px;color:#888;">Loading disputes…</p>
    }
    else
    {
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Ticket ID</th>
                    <th>Involved Parties</th>
                    <th>Issue Details</th>
                    <th>Priority</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ticket in FilteredTickets)
                {
                    <tr>
                        <td style="color:#666; font-family:monospace;">#@ticket.Id.ToString("N")[..8]</td>
                        <td>
                            <div style="font-weight:600;">@(ticket.ConsumerName ?? "—")</div>
                            <small style="color:#888;">vs @(ticket.ProviderName ?? "—")</small>
                        </td>
                        <td>
                            <div style="color:#ddd;">@ticket.IssueType</div>
                            <small style="color:#666; display:block; max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                @ticket.Description
                            </small>
                        </td>
                        <td>
                            <span class="@GetPriorityClass(ticket.Priority)" style="font-weight:600; font-size:0.9rem;">
                                <span class="priority-dot"></span> @ticket.Priority
                            </span>
                        </td>
                        <td style="color:#888;">@ticket.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            <span class="badge-status @(ticket.Status == "Pending" ? "status-pending" : "status-resolved")">
                                @if (ticket.Status == "Pending")
                                {
                                    <i class="fa-solid fa-circle-exclamation"></i>
                                }
                                else
                                {
                                    <i class="fa-solid fa-check"></i>
                                }
                                @ticket.Status
                            </span>
                        </td>
                        <td>
                            <button type="button" class="btn-action" @onclick="() => OpenTicket(ticket)">
                                @(ticket.Status == "Pending" ? "Resolve" : "Details")
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@if (showModal && selectedTicket != null)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <button type="button" class="close-btn" @onclick="CloseModal"><i class="fa-solid fa-xmark"></i></button>

            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; padding-right: 25px;">
                <h3 style="margin:0; font-weight:700;">Ticket #@selectedTicket.Id.ToString("N")[..8]</h3>
                <span class="badge-status @(selectedTicket.Status == "Pending" ? "status-pending" : "status-resolved")">
                    @selectedTicket.Status
                </span>
            </div>

            <div class="info-group">
                <span class="info-label">Issue Type</span>
                <div class="info-value" style="display:flex; align-items:center;">
                    @selectedTicket.IssueType
                    <span class="@GetPriorityClass(selectedTicket.Priority)" style="margin-left:15px; font-size:0.8rem; font-weight:bold;">
                        (@selectedTicket.Priority Priority)
                    </span>
                </div>
            </div>

            <div class="info-group">
                <span class="info-label">Description</span>
                <div class="desc-box">
                    "@selectedTicket.Description"
                </div>
            </div>

            <div class="info-group" style="display:grid; grid-template-columns: 1fr 1fr; gap:10px;">
                <div>
                    <span class="info-label">Customer</span>
                    <div class="info-value">@(selectedTicket.ConsumerName ?? "—")</div>
                </div>
                <div>
                    <span class="info-label">Vendor</span>
                    <div class="info-value">@(selectedTicket.ProviderName ?? "—")</div>
                </div>
            </div>

            <hr style="border-color:rgba(255,255,255,0.1); margin: 20px 0;">

            @if (selectedTicket.Status == "Pending")
            {
                <div>
                    <span class="info-label">Admin Resolution</span>
                    <textarea class="admin-textarea" rows="3" placeholder="Enter resolution notes or outcome..." @bind="resolutionDraft"></textarea>

                    <button type="button" class="btn-resolve-submit" disabled="@isSubmitting" @onclick="SubmitResolveAsync">
                        <i class="fa-solid fa-gavel"></i> Mark as Resolved
                    </button>
                </div>
            }
            else
            {
                <div style="padding:15px; background:rgba(46, 204, 113, 0.1); border:1px solid #2ecc71; border-radius:8px; color:#2ecc71; display:flex; align-items:center; gap:10px;">
                    <i class="fa-solid fa-circle-check"></i>
                    <div>
                        <strong>Case Closed</strong>
                        <div style="font-size:0.8rem; opacity:0.8;">Resolution has been provided and ticket is closed.</div>
                    </div>
                </div>
            }
        </div>
    </div>
}
